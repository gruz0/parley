# Normalize line endings. Shell scripts and the Makefile MUST stay LF, or they
# break on WSL/Linux with `bad interpreter: /bin/bash^M`.
* text=auto eol=lf
*.sh text eol=lf
Makefile text eol=lf

# Binary assets — never diff or normalize these.
*.png binary
*.gif binary

# Keep the lockfile out of diffs and language stats.
bun.lock -diff linguist-generated
